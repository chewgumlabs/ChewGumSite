{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanecurry.com/schemas/pass-evidence-policy.v0.json",
  "title": "Authority Pass Evidence Policy",
  "type": "object",
  "required": ["schema_version", "policies"],
  "properties": {
    "schema_version": { "const": "pass-evidence-policy.v0" },
    "updated": { "type": "string" },
    "description": { "type": "string" },
    "policies": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["source_url_always_allowed"],
        "properties": {
          "description": { "type": "string" },
          "source_url_always_allowed": { "type": "boolean" },
          "own_site_exact_paths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "own_site_path_prefixes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "external_url_prefixes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "seed_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
