  "aliases": [
    {
      "from": "Status",
      "to": "Current Status",
      "reason": "Avoid bare status labels drifting from the section-index phrase."
    },
    {
      "from": "Promotion Rule",
      "to": "Publication Boundary",
      "reason": "The public meaning is a boundary for publication, not pressure to promote."
    },
    {
      "from": "Why Here",
      "to": "Section Summary",
      "reason": "Index pages should use a general summary window unless the heading is part of prose."
    },
    {
      "from": "Why This Page Exists",
      "to": "Public Purpose",
      "reason": "Public-facing purpose is clearer than an internal rationale phrase."
    },
    {
      "from": "Live Prototype",
      "to": "Live Artifact",
      "reason": "Prototype can imply unfinished public status unless that is intentional."
    },
    {
      "from": "Facts And Definitions",
      "to": "Definitions",
      "reason": "The current title mixes glossary links and factual proof; split or rename when cleaning up."
    },
    {
      "from": "Working Facts",
      "to": "Profile Facts",
      "reason": "Less provisional for a stable public profile."
    },
    {
      "from": "Working Scope",
      "to": "Public Scope",
      "reason": "Less provisional for a stable public section page."
    },
    {
      "from": "Current Direction",
      "to": "Current Focus",
      "reason": "Align with homepage language unless a distinct distinction is needed."
    },
    {
      "from": "Current Tools",
      "to": "Tool Index",
      "reason": "Sibling indexes should use parallel naming: Tool Index, Toy Index, Blog Index."
    },
    {
      "from": "Record Status",
      "to": "Verification Status",
      "reason": "Record Status reads internal; the public meaning is verification/completeness state."
    }
  ],
  "entry_types": [
    "metadata_pair",
