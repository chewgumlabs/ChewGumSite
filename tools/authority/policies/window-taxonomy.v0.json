  ],
  "reserved_titles": [
    {
      "title": "External Implementations",
      "description": "Third-party projects that used or incorporated a public ChewGum tool/repo. This does not imply customer, client, collaboration, endorsement, partnership, adoption, official integration, or case-study status."
    }
  ],
  "notes": [
    "Easing Formulas may be a standalone toy window when motion curves are the lesson; otherwise formulas can be entries inside Demo Parameters or Technical Parameters.",
    "Human-authored essays may use expressive section titles. Do not normalize prose titles unless the page opts into structured-note behavior.",
    "This policy starts advisory. Use audit findings for review before graduating any rule to a blocking validator gate."
  ]
