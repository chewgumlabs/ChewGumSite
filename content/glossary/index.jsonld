    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "DefinedTermSet",
      "@id": "https://shanecurry.com/glossary/#termset",
      "name": "Shane Curry Glossary",
      "url": "https://shanecurry.com/glossary/",
      "description": "Animation basics and working terms used across Shane Curry's site, starting with core animation concepts that can link outward to toys and essays.",
      "creator": {
        "@id": "https://shanecurry.com/#person"
      },
      "isPartOf": {
        "@id": "https://shanecurry.com/#website"
      },
      "hasDefinedTerm": [
        {
          "@type": "DefinedTerm",
          "name": "Timing",
          "description": "Timing is how long an action takes to complete.",
          "url": "https://shanecurry.com/glossary/#timing",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Spacing",
          "description": "Spacing is how positions cluster or spread across a path over time.",
          "url": "https://shanecurry.com/glossary/#spacing",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Ease In",
          "description": "Ease in concentrates spacing near the end of a move so motion settles into the stop.",
          "url": "https://shanecurry.com/glossary/#ease-in",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Ease Out",
          "description": "Ease out concentrates spacing near the beginning of a move so motion accelerates away from the start.",
          "url": "https://shanecurry.com/glossary/#ease-out",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Ease In + Out",
          "description": "Ease in and out clusters spacing near both ends so motion starts and stops gently.",
          "url": "https://shanecurry.com/glossary/#ease-in-out",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Arcs",
          "description": "Arcs describe curved motion paths that make movement feel more organic and less mechanical.",
          "url": "https://shanecurry.com/glossary/#arcs",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Anticipation",
          "description": "Anticipation is a preparatory action that sets up the main action and helps the audience read it.",
          "url": "https://shanecurry.com/glossary/#anticipation",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Staging",
          "description": "Staging is the arrangement of poses, timing, and composition so the audience reads the intended idea clearly.",
          "url": "https://shanecurry.com/glossary/#staging",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Silhouette",
          "description": "Silhouette is the readable outer shape of a pose when internal details are removed.",
          "url": "https://shanecurry.com/glossary/#silhouette",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Key Pose",
          "description": "A key pose is a major storytelling or structural pose that defines the important beats of an action.",
          "url": "https://shanecurry.com/glossary/#key-pose",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Animation Fundamentals",
          "description": "Animation fundamentals are durable motion and staging ideas that help an audience read action, character intent, rhythm, and visual emphasis.",
          "url": "https://shanecurry.com/glossary/#animation-fundamentals",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Motion Readability",
          "description": "Motion readability is how clearly a viewer can understand what changed, why it changed, and where to look while the action is happening.",
          "url": "https://shanecurry.com/glossary/#motion-readability",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Follow Through",
          "description": "Follow through is the continuation of motion after the main body has stopped or changed direction.",
          "url": "https://shanecurry.com/glossary/#follow-through",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Overlap",
          "description": "Overlap is the offset timing between connected parts so they do not all start and stop at once.",
          "url": "https://shanecurry.com/glossary/#overlap",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Procedural Animation",
          "description": "Procedural animation is motion generated or modified by rules, formulas, or code rather than fixed keyframes alone.",
          "url": "https://shanecurry.com/glossary/#procedural-animation",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Displacement Field",
          "description": "A displacement field is a set of values across a surface that tells sampled points how far, or in what direction, to move.",
          "url": "https://shanecurry.com/glossary/#displacement-field",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Sampling",
          "description": "Sampling is the act of reading a continuous rule, signal, or path at discrete points so it can be drawn, animated, tested, or heard.",
          "url": "https://shanecurry.com/glossary/#sampling",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Sine Wave",
          "description": "A sine wave is a smooth repeating wave that oscillates between high and low values and is useful for cyclic motion, sound, and displacement.",
          "url": "https://shanecurry.com/glossary/#sine-wave",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Stroke Smoothing",
          "description": "Stroke smoothing is the process of turning noisy pointer samples into a cleaner path while preserving enough timing and shape to feel hand-drawn.",
          "url": "https://shanecurry.com/glossary/#stroke-smoothing",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Real-Time Audio",
          "description": "Real-time audio is sound generated or controlled while an interaction is happening, instead of being rendered ahead of time as a fixed file.",
          "url": "https://shanecurry.com/glossary/#real-time-audio",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Software Rendering",
          "description": "Software rendering draws graphics on the CPU or ordinary program code path rather than relying primarily on a hardware graphics pipeline.",
          "url": "https://shanecurry.com/glossary/#software-rendering",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Raymarching",
          "description": "Raymarching is a rendering technique that steps along a ray through a scene until it finds a surface or reaches a limit.",
          "url": "https://shanecurry.com/glossary/#raymarching",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "DDA Raycaster",
          "description": "A DDA raycaster steps through a grid one cell boundary at a time to find wall hits, a classic way to render simple first-person rooms.",
          "url": "https://shanecurry.com/glossary/#dda-raycaster",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Oscilloscope Effect",
          "description": "An oscilloscope effect renders a scene as bright traced lines, borrowing the look of signal display rather than shaded surfaces.",
          "url": "https://shanecurry.com/glossary/#oscilloscope-effect",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Web Audio",
          "description": "Web Audio is the browser API used to synthesize, schedule, route, and process audio in interactive web pages.",
          "url": "https://shanecurry.com/glossary/#web-audio",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Native Triangle Oscillator",
          "description": "A native triangle oscillator is the browser's built-in triangle oscillator type, useful as a baseline tone source in Web Audio comparisons.",
          "url": "https://shanecurry.com/glossary/#native-triangle-oscillator",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Triangle Wave",
          "description": "A triangle wave is a periodic waveform with linear rises and falls, often softer than a square wave and brighter than a sine wave.",
          "url": "https://shanecurry.com/glossary/#triangle-wave",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Periodic Wave",
          "description": "A PeriodicWave is a Web Audio waveform built from harmonic data so custom oscillator shapes can be played by the browser.",
          "url": "https://shanecurry.com/glossary/#periodic-wave",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "NES Audio",
          "description": "NES audio refers to the constrained sound-generation style of the Nintendo Entertainment System, including its distinctive triangle channel.",
          "url": "https://shanecurry.com/glossary/#nes-audio",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Audio Synthesis",
          "description": "Audio synthesis is the generation of sound from rules, waveforms, samples, or signal-processing graphs instead of playing only recorded audio.",
          "url": "https://shanecurry.com/glossary/#audio-synthesis",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Dithering",
          "description": "Dithering is a reduction technique that uses patterned or distributed pixels to suggest colors or values that are not directly available in the active palette.",
          "url": "https://shanecurry.com/glossary/#dithering",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Palette Reduction",
          "description": "Palette reduction maps an image into a smaller set of allowed colors, making the choice of palette part of the visible result.",
          "url": "https://shanecurry.com/glossary/#palette-reduction",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Error Diffusion",
          "description": "Error diffusion is a dithering method that spreads each pixel's quantization error into neighboring pixels so the local mistakes become a larger texture.",
          "url": "https://shanecurry.com/glossary/#error-diffusion",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Contract-First",
          "description": "Contract-first is a methodology where formal contracts and validators are written before implementation, so creative software stays auditable as it grows. The contract specifies inputs, outputs, and invariants; the implementation must satisfy the contract. ChewGum Animation uses contract-first as its primary discipline.",
          "url": "https://shanecurry.com/glossary/#contract-first",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Interpretation Context",
          "description": "An interpretation context is a named context that determines how drawn stroke data is read. The same stroke can become a line on a page, a motion path, or a musical note depending on which interpretation context is active.",
          "url": "https://shanecurry.com/glossary/#interpretation-context",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Chew",
          "description": "Chew is a character role across ChewGum products representing exploration, play, surprise, variant generation, and what-if thinking. Chew is paired with Gum across all ChewGum interfaces.",
          "url": "https://shanecurry.com/glossary/#chew",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        },
        {
          "@type": "DefinedTerm",
          "name": "Gum",
          "description": "Gum is a character role across ChewGum products representing truth, cleanup, contracts, provenance, and verification. Gum is paired with Chew across all ChewGum interfaces.",
          "url": "https://shanecurry.com/glossary/#gum",
          "inDefinedTermSet": {
            "@id": "https://shanecurry.com/glossary/#termset"
          }
        }
      ]
    }
  ]
}
    </script>
